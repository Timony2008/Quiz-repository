generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  quizzes   Quiz[]
  quizSets  QuizSet[]
  createdAt DateTime  @default(now())
}

model QuizSet {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  author      User            @relation(fields: [authorId], references: [id])
  authorId    Int
  quizzes     Quiz[]
  tags        TagOnQuizSet[]  // ✅ 新增：题库标签
  createdAt   DateTime        @default(now())
}

model Quiz {
  id           Int          @id @default(autoincrement())
  question     String
  answer       String
  isLabeled    Boolean      @default(false)
  author       User         @relation(fields: [authorId], references: [id])
  authorId     Int
  quizSet      QuizSet?     @relation(fields: [quizSetId], references: [id])
  quizSetId    Int?
  sourceFile   SourceFile?  @relation(fields: [sourceFileId], references: [id])
  sourceFileId Int?
  tags         TagOnQuiz[]
  createdAt    DateTime     @default(now())

  @@index([sourceFileId])
  @@index([isLabeled])
  @@index([createdAt])
}

model Tag {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  color       String?
  quizzes     TagOnQuiz[]
  quizSets    TagOnQuizSet[] // ✅ 新增：反向关联
  createdAt   DateTime       @default(now())
}

model TagOnQuiz {
  quiz   Quiz @relation(fields: [quizId], references: [id])
  quizId Int
  tag    Tag  @relation(fields: [tagId], references: [id])
  tagId  Int

  @@id([quizId, tagId])
}

// ✅ 新增：题库 <-> 标签 中间表
model TagOnQuizSet {
  quizSet   QuizSet @relation(fields: [quizSetId], references: [id])
  quizSetId Int
  tag       Tag     @relation(fields: [tagId], references: [id])
  tagId     Int

  @@id([quizSetId, tagId])
}

model SourceFile {
  id         Int      @id @default(autoincrement())
  filename   String
  storedPath String
  fileType   String
  status     String   @default("PROCESSING")
  errorMsg   String?
  quizCount  Int      @default(0)
  quizzes    Quiz[]
  createdAt  DateTime @default(now())
}
