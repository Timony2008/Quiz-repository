generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  password String
  quizSets QuizSet[]
}

model QuizSet {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
  quizzes     Quiz[]
}

model Quiz {
  id           Int          @id @default(autoincrement())
  question     String
  answer       String
  quizSetId    Int
  quizSet      QuizSet      @relation(fields: [quizSetId], references: [id])
  tags         TagOnQuiz[]
  sourceFileId Int?
  sourceFile   SourceFile?  @relation(fields: [sourceFileId], references: [id])
}

model Tag {
  id      Int         @id @default(autoincrement())
  name    String      @unique
  quizzes TagOnQuiz[]
}

model TagOnQuiz {
  quizId Int
  tagId  Int
  quiz   Quiz @relation(fields: [quizId], references: [id])
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([quizId, tagId])
}

model SourceFile {
  id         Int      @id @default(autoincrement())
  filename   String
  storedPath String
  fileType   String
  status     String   @default("PROCESSING")
  errorMsg   String?
  quizCount  Int?
  createdAt  DateTime @default(now())
  quizzes    Quiz[]
}
