generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  password String
  quizSets QuizSet[]
}

model QuizSet {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  visibility  String  @default("PRIVATE")
  authorId    Int
  author      User    @relation(fields: [authorId], references: [id])
  quizzes     Quiz[]
  privateTags Tag[]                      // ← 新增
}


model Quiz {
  id           Int         @id @default(autoincrement())
  question     String
  answer       String
  quizSetId    Int
  quizSet      QuizSet     @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  tags         QuizTag[]
  difficulty   Float?
  order        Int         @default(0)
  updatedAt    DateTime    @updatedAt
  sourceFileId Int?
  sourceFile   SourceFile? @relation(fields: [sourceFileId], references: [id])
}

model Tag {
  id         Int       @id @default(autoincrement())
  name       String
  dimension  String?   @default("CONTEXT")   // ← 加这行
  isGlobal   Boolean   @default(false)   // true = 管理员维护的全局标签
  parentId   Int?                        // 仅全局标签使用层级
  parent     Tag?      @relation("TagHierarchy", fields: [parentId], references: [id])
  children   Tag[]     @relation("TagHierarchy")
  quizSetId  Int?  @default(0)                        // 私有标签归属题库，全局标签为 null
  quizSet    QuizSet?  @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  quizzes    QuizTag[]
  createdAt  DateTime  @default(now())
  @@unique([name, quizSetId])            // 同一题库内标签名唯一；全局标签 quizSetId=null 也唯一
}

model QuizTag {
  quizId Int
  tagId  Int
  order  Int  @default(0)               // ← 新增，控制 chip 显示顺序
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([quizId, tagId])
}

model SourceFile {
  id         Int      @id @default(autoincrement())
  filename   String
  storedPath String
  fileType   String   // "TEX" | "PDF"
  status     String   // "PROCESSING" | "DONE" | "FAILED"
  quizCount  Int?
  errorMsg   String?
  createdAt  DateTime @default(now())
  quizzes    Quiz[]
}
