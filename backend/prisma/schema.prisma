generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  password String
  quizSets QuizSet[]
}

model QuizSet {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  visibility  String  @default("PRIVATE")
  authorId    Int
  author      User    @relation(fields: [authorId], references: [id])
  quizzes     Quiz[]
  privateTags Tag[]
}

model Quiz {
  id           Int         @id @default(autoincrement())
  question     String
  answer       String
  quizSetId    Int
  quizSet      QuizSet     @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  tags         QuizTag[]
  difficulty   Float?
  note         String?
  order        Int         @default(0)
  updatedAt    DateTime    @updatedAt
  sourceFileId Int?
  sourceFile   SourceFile? @relation(fields: [sourceFileId], references: [id])
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  dimension String   @default("CONTEXT") // KNOWLEDGE | METHOD | SOURCE | CONTEXT
  isGlobal  Boolean  @default(false)

  parentId Int?
  parent   Tag?   @relation("TagHierarchy", fields: [parentId], references: [id])
  children Tag[]  @relation("TagHierarchy")

  quizSetId Int?
  quizSet   QuizSet? @relation(fields: [quizSetId], references: [id], onDelete: Cascade)

  quizzes   QuizTag[]
  createdAt DateTime @default(now())

  @@unique([name, quizSetId])
}

model QuizTag {
  quizId Int
  tagId  Int
  order  Int  @default(0)
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([quizId, tagId])
}

model SourceFile {
  id         Int      @id @default(autoincrement())
  filename   String
  storedPath String
  fileType   String
  status     String
  quizCount  Int?
  errorMsg   String?
  createdAt  DateTime @default(now())
  quizzes    Quiz[]
}
