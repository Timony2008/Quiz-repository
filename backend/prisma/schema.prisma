generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  password String
  quizSets QuizSet[]
}

model QuizSet {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  visibility  String  @default("PRIVATE")
  authorId    Int
  author      User    @relation(fields: [authorId], references: [id])
  quizzes     Quiz[]
}

model Quiz {
  id           Int         @id @default(autoincrement())
  question     String
  answer       String
  quizSetId    Int
  quizSet      QuizSet     @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  tags         QuizTag[]
  difficulty   Float?
  order        Int         @default(0)
  updatedAt    DateTime    @updatedAt
  sourceFileId Int?
  sourceFile   SourceFile? @relation(fields: [sourceFileId], references: [id])
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  // dimension 取值: "KNOWLEDGE" | "SOURCE" | "YEAR" | "METHOD" | "CONTEXT"
  dimension String    @default("KNOWLEDGE")
  parentId  Int?                                        // 仅 KNOWLEDGE 维度使用
  parent    Tag?      @relation("TagHierarchy", fields: [parentId], references: [id])
  children  Tag[]     @relation("TagHierarchy")
  aliases   String    @default("[]")                   // JSON 字符串，如 '["数论","NT"]'
  quizzes   QuizTag[]
  createdAt DateTime  @default(now())
}

model QuizTag {
  quizId Int
  tagId  Int
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([quizId, tagId])
}

model SourceFile {
  id         Int      @id @default(autoincrement())
  filename   String
  storedPath String
  fileType   String   // "TEX" | "PDF"
  status     String   // "PROCESSING" | "DONE" | "FAILED"
  quizCount  Int?
  errorMsg   String?
  createdAt  DateTime @default(now())
  quizzes    Quiz[]
}
