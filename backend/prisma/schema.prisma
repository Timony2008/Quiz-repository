generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  password String
  quizSets QuizSet[]
}

model QuizSet {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  visibility  String     @default("PRIVATE")
  authorId    Int
  author      User       @relation(fields: [authorId], references: [id])
  quizzes     Quiz[]
}

model Quiz {
  id           Int         @id @default(autoincrement())
  question     String
  answer       String
  quizSetId    Int
  quizSet      QuizSet     @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  tags         QuizTag[]
  difficulty   Float?                       // ← Int? 改为 Float?
  order        Int         @default(0)
  updatedAt    DateTime    @updatedAt      // ← 新增
  sourceFileId Int?
  sourceFile   SourceFile? @relation(fields: [sourceFileId], references: [id])
}

model Tag {
  id      Int       @id @default(autoincrement())
  name    String    @unique
  quizzes QuizTag[]
}

model QuizTag {
  quizId Int
  tagId  Int
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id])

  @@id([quizId, tagId])
}

// ✅ 全新模型
model SourceFile {
  id         Int      @id @default(autoincrement())
  filename   String
  storedPath String
  fileType   String   // "TEX" | "PDF"
  status     String   // "PROCESSING" | "DONE" | "FAILED"
  quizCount  Int?
  errorMsg   String?
  createdAt  DateTime @default(now())
  quizzes    Quiz[]
}
